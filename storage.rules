rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /renacer_secure_pdfs/{fileName} {

      // Cualquier persona puede DESCARGAR/VER los PDFs (son documentos públicos).
      allow read: if true;

      // Solo un usuario autenticado puede SUBIR o REEMPLAZAR archivos,
      // y solo si es un PDF de máximo 15 MB.
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';

      // Solo un usuario autenticado puede ELIMINAR archivos.
      allow delete: if request.auth != null;
    }
  }
}
